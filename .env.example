# Copy this file to ".env" and fill in real values.
# ".env" itself is gitignored — never commit real tokens/chat IDs.
# This file (.env.example) has no secrets, so it's safe to commit.

TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# Optional — enables a suggested position size in each trade plan.
# Leave blank/unset to skip position sizing entirely (default).
# ACCOUNT_SIZE=100000
# RISK_PER_TRADE_PCT=1.0
